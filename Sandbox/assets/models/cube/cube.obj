# Unit cube with face normals and UV coordinates
# Centered at origin, half-extents 0.5
# 6 faces, 2 triangles each, CCW winding (normals outward)

mtllib cube.mtl
o Cube

# 8 corner positions
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

# UV coordinates (quad layout)
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Face normals (one per face direction)
vn  0.0  0.0 -1.0
vn  0.0  0.0  1.0
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0
vn  0.0 -1.0  0.0
vn  0.0  1.0  0.0

usemtl Cube

# -Z face (normal 1: 0,0,-1) -- outward normal toward -Z
f 1/1/1 3/3/1 2/2/1
f 1/1/1 4/4/1 3/3/1

# +Z face (normal 2: 0,0,+1) -- outward normal toward +Z
f 5/2/2 6/1/2 7/4/2
f 5/2/2 7/4/2 8/3/2

# -X face (normal 3: -1,0,0) -- outward normal toward -X
f 1/1/3 5/2/3 8/3/3
f 1/1/3 8/3/3 4/4/3

# +X face (normal 4: +1,0,0) -- outward normal toward +X
f 2/4/4 3/3/4 7/2/4
f 2/4/4 7/2/4 6/1/4

# -Y face (normal 5: 0,-1,0) -- outward normal toward -Y
f 1/1/5 6/2/5 5/4/5
f 1/1/5 2/2/5 6/3/5

# +Y face (normal 6: 0,+1,0) -- outward normal toward +Y
f 4/1/6 7/2/6 3/3/6
f 4/1/6 8/4/6 7/3/6
